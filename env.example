# ========================================
# FOREX SIGNAL BOT - .env konfiguracija
# Kopiraj to datoteko v .env in izpolni vrednosti
# NIKOLI ne commitaj .env v git!
# ========================================

# Alpha Vantage API ključ (brezplačen na alphavantage.co)
ALPHA_VANTAGE_API_KEY=tvoj_alpha_vantage_api_kljuc

# SendGrid API ključ (za pošiljanje emailov)
SENDGRID_API_KEY=SG.tvoj_sendgrid_api_kljuc

# Email naslovi
EMAIL_FROM=tvoj_verificiran@email.com
EMAIL_TO=prejemnik@email.com

# Logging nivo (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
